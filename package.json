{
  "name": "@inland/monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "tsc": "tsc -b tsconfig.json --verbose",
    "codegen": "tsx ./scripts/gen-ts-config.ts",
    "lint:ox": "oxlint .",
    "lint:eslint": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" eslint . --cache",
    "lint:eslint:fix": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" eslint . --cache --fix",
    "lint:fmt": "oxfmt --check",
    "lint:fmt:fix": "oxfmt",
    "commitlint": "commitlint --edit",
    "dev:fe": "yarn workspace @inland/frontend dev",
    "dev:be": "yarn workspace @inland/backend dev",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@inland/dev": "workspace:*",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/ui": "^4.0.0",
    "cross-env": "^10.0.0",
    "eslint": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "oxlint": "^1.51.0",
    "tsx": "^4.20.4",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.40.0",
    "vitest": "^4.0.0"
  },
  "devDependencies": {
    "eslint-plugin-react-hooks": "^7.0.1",
    "oxfmt": "^0.42.0",
    "oxlint-tsgolint": "^0.18.0"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{ts,tsx,mjs,js,jsx}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" eslint --cache --fix"
    ]
  },
  "packageManager": "yarn@4.13.0"
}
